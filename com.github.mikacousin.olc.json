    {
      "name": "liblo",
      "config-opts": [
        "--disable-examples",
        "--disable-tools"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/radarsat1/liblo.git",
          "tag": "0.35",
          "commit": "1d3cd7c8c76e6b25ee5ff35ad1356c2c8d25ac05"
        }
      ]
    },
    {
      "name": "python3-pyliblo3",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -c \"import re; p='pyliblo3/_liblo.pyx'; c=open(p).read().replace('long(value)', 'int(value)').replace('(int, long)', 'int').replace('(float, int, long)', '(float, int)'); open(p,'w').write(c)\"",
        "pip3 install --verbose --no-index --prefix=${FLATPAK_DEST} . --no-build-isolation"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://files.pythonhosted.org/packages/12/18/788fdfa78afc40306bb1ae86ef591c0db51ab2691cd31a5096401ed3bf2f/pyliblo3-0.16.3.tar.gz",
